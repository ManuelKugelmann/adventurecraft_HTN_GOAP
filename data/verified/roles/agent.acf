role agent [universal, L1] {

    # ── Base agent role ───────────────────────────────────────────────
    #
    # Present on every entity with a Drives trait. All specialized roles
    # inherit from this: role guard : agent, role farmer : agent, etc.
    #
    # All drive-triggered behaviors are involuntary to some degree.
    # Degree of involuntariness = priority (polled) or strength (event-triggered).
    # will_suppressed(actor, threshold) determines if the agent can resist:
    #   will_strength(actor) >= threshold → agent can suppress the urge
    #   will_strength(actor) <  threshold → behavior fires compulsorily
    #
    # Polled behaviors use `priority` as both the scheduler weight and will threshold.
    # Event-triggered behaviors use `strength = expr` (dynamic, scaled by event magnitude).
    # Goal plan steps have no will check — they are fully voluntary.
    #
    # Drive scale: deprivation. 0 = fully satisfied, 100 = critical deprivation.
    #   > 80 = critical  — will threshold so high most agents cannot suppress
    #   60-80 = urgent   — elevated priority, requires trained will to push through
    #   30-60 = present  — manageable, moderate will suppresses easily
    #   < 30  = low      — easily ignored, only suppressed if will is very low
    #
    # Priority scale context (from guard role):
    #   patrol = 5, alert = 45, defend = 50, arrest = 40

    # ── Overwhelming (priority 90-100, near-impossible to suppress) ────

    flee_lethal_threat: when self.Vitals.Health < 20
                            AND nearby(self, 20).any(hostile)
                            AND NOT capable(self, combat),
                        do flee_danger { threat = nearby(self, 20).filter(hostile).closest },
                        priority = 95

    tend_wounds_critical: when self.Vitals.Health < 20,
                          do tend_wound { target = self },
                          priority = 90

    # Event-triggered: strength scales with event magnitude, not a fixed level.
    # An agent with very high willpower may suppress a minor blow (strength 5)
    # but not a devastating hit (strength 80+).

    collapse: when self.Vitals.Health < 10,
              do incapacitate { },
              strength = 100

    fear_freeze: when visible(self, $threat)
                     AND combat_chance($threat, self) > 0.85
                     AND self.Drives.fear > 60,
                 do freeze { target = $threat, duration = 2 },
                 strength = combat_chance($threat, self) * 80
                            + self.Drives.fear * 0.3

    pain_flinch: when damage_received > 0,
                 do interrupt_current_action { duration = 1 },
                 strength = damage_received * 0.5

    startle: when sudden_event(nearby(self, 10))
                 AND NOT self.knows(performed(event.source, any)),
             do interrupt_current_action { },
             strength = 20

    # ── Urgent (priority 60-80, trained will can suppress) ────────────

    drink_urgent: when self.Drives.thirst > 80,
                  do drink { source = nearby(self, 50).filter(type = water).closest },
                  priority = 75

    eat_urgent: when self.Drives.hunger > 80,
                do eat { source = nearby(self, 50).filter(Edible).closest },
                priority = 70

    seek_shelter_urgent: when self.Drives.exposure > 80
                             AND weather.severity > 3,
                         do find_shelter { region = self.location },
                         priority = 68

    tend_wound_urgent: when self.Vitals.Health < 40,
                       do tend_wound { target = self },
                       priority = 65

    rest_urgent: when self.Drives.fatigue > 80,
                 do rest { location = self.location },
                 priority = 60

    # ── Present (priority 20-35, easily suppressed by moderate will) ──

    drink_present: when self.Drives.thirst > 60,
                   do drink { source = nearby(self, 50).filter(type = water).closest },
                   priority = 35

    eat_present: when self.Drives.hunger > 60,
                 do eat { source = nearby(self, 50).filter(Edible).closest },
                 priority = 30

    rest_present: when self.Drives.fatigue > 60,
                  do rest { location = self.location },
                  priority = 20

    # ── Awareness baseline (always-on, suppressed by nearly any will) ─

    ambient_awareness: when self.Drives.alertness > 20,
                       do Sense.Indirect { target = nearby(self, 20) },
                       priority = 3

}

_provenance {
    sources = [{ type = design_pattern, id = drive_architecture, confidence = 0.9 }]
    model = seed
    verified = false
    reviewer = pending
}
